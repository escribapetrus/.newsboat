# General
auto-reload yes
reload-time 30
reload-threads 4
show-read-feeds no
show-read-articles no
prepopulate-query-feeds yes
feed-sort-order none

# Display
articlelist-format "%4i %f %D  %?T?|%-17T|  ?%t"
feedlist-format "%4i %n %11u %T %t"
datetime-format "%b %d"
text-width 80

# Browser
browser "open %u"
confirm-mark-feed-read no

# Notifications
notify-format "newsboat: %n unread articles in %f unread feeds"

# Vim keybindings
bind-key j down
bind-key k up
bind-key j next articlelist
bind-key k prev articlelist
bind-key J next-feed articlelist
bind-key K prev-feed articlelist
bind-key G end
bind-key g home
bind-key d pagedown
bind-key u pageup
bind-key l open
bind-key h quit
bind-key a toggle-article-read
bind-key n next-unread
bind-key N prev-unread
bind-key D pb-download
bind-key U show-urls
bind-key x pb-delete

# Macros
macro o open-in-browser ; toggle-article-read "read"
macro v set browser "open %u" ; open-in-browser ; set browser "open %u"
